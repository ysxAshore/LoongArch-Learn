From 3ade00c67f2d8d23f7d1591d0e7a9c0a1c465af0 Mon Sep 17 00:00:00 2001
From: liangliang678 <wujunliang@loongson.cn>
Date: Thu, 6 Jul 2023 10:13:07 +0800
Subject: [PATCH] exp9

---
 exe_stage.v |  5 ++--
 id_stage.v  | 74 ++++++++++++++++++++++++++++++-----------------------
 mem_stage.v |  4 +--
 mycpu.h     |  6 ++---
 mycpu_top.v | 20 +++++++--------
 wb_stage.v  |  4 +--
 6 files changed, 62 insertions(+), 51 deletions(-)

diff --git a/exe_stage.v b/exe_stage.v
index acc296f..f6927a2 100644
--- a/exe_stage.v
+++ b/exe_stage.v
@@ -13,7 +13,7 @@ module exe_stage(
     output wire                         es_to_ms_valid,
     output wire [`ES_TO_MS_BUS_WD -1:0] es_to_ms_bus  ,
     //to ds
-    output wire [`ES_TO_DS_STALL_BUS - 1:0] es_to_ds_stall_bus,
+    output wire [`ES_TO_DS_FORWARD_BUS - 1:0] es_to_ds_forward_bus,
     // data sram interface
     output wire        data_sram_en   ,
     output wire [ 3:0] data_sram_we   ,
@@ -91,7 +91,8 @@ alu u_alu(
     .alu_result (es_alu_result)
 );
 
-assign es_to_ds_stall_bus = {es_valid && es_gr_we, es_dest};
+wire dep_need_stall = es_valid && es_res_from_mem;
+assign es_to_ds_forward_bus = {dep_need_stall, es_valid && es_gr_we, es_dest, es_alu_result};
 
 assign data_sram_en    = (es_res_from_mem || es_mem_we) && es_valid;
 assign data_sram_we    = es_mem_we ? 4'hf : 4'h0;
diff --git a/id_stage.v b/id_stage.v
index f00d2ff..0702715 100644
--- a/id_stage.v
+++ b/id_stage.v
@@ -9,10 +9,10 @@ module id_stage(
     //from fs 
     input  wire                         fs_to_ds_valid,
     input  wire [`FS_TO_DS_BUS_WD -1:0] fs_to_ds_bus  ,
-    //stall
-    input  wire [`ES_TO_DS_STALL_BUS - 1:0] es_to_ds_stall_bus,
-    input  wire [`MS_TO_DS_STALL_BUS - 1:0] ms_to_ds_stall_bus,
-    input  wire [`WS_TO_DS_STALL_BUS - 1:0] ws_to_ds_stall_bus,
+    //forward path
+    input  wire [`ES_TO_DS_FORWARD_BUS - 1:0] es_to_ds_forward_bus,
+    input  wire [`MS_TO_DS_FORWARD_BUS - 1:0] ms_to_ds_forward_bus,
+    input  wire [`WS_TO_DS_FORWARD_BUS - 1:0] ws_to_ds_forward_bus,
     //to es
     output wire                         ds_to_es_valid,
     output wire [`DS_TO_ES_BUS_WD -1:0] ds_to_es_bus  ,
@@ -109,29 +109,37 @@ wire [31:0] rj_value;
 wire [31:0] rkd_value;
 wire [31:0] ds_imm;
 
-// stall
+// forward and stall
 wire inst_need_rj;
 wire inst_need_rkd;
 wire rf1_stall;
 wire rf2_stall;
 
-wire       es_stall_valid;
-wire [4:0] es_stall_reg;
-assign {es_stall_valid,
-        es_stall_reg
-       } = es_to_ds_stall_bus;
-
-wire       ms_stall_valid;
-wire [4:0] ms_stall_reg;
-assign {ms_stall_valid,
-        ms_stall_reg
-       } = ms_to_ds_stall_bus;
-
-wire       ws_stall_valid;
-wire [4:0] ws_stall_reg;
-assign {ws_stall_valid,
-        ws_stall_reg
-       } = ws_to_ds_stall_bus;
+wire        es_dep_need_stall;
+wire        es_forward_enable;
+wire [ 4:0] es_forward_reg;
+wire [31:0] es_forward_data;
+assign {es_dep_need_stall,
+        es_forward_enable,
+        es_forward_reg,
+        es_forward_data
+       } = es_to_ds_forward_bus;
+
+wire        ms_forward_enable;
+wire [ 4:0] ms_forward_reg;
+wire [31:0] ms_forward_data;
+assign {ms_forward_enable,
+        ms_forward_reg,
+        ms_forward_data
+       } = ms_to_ds_forward_bus;
+
+wire        ws_forward_enable;
+wire [ 4:0] ws_forward_reg;
+wire [31:0] ws_forward_data;
+assign {ws_forward_enable,
+        ws_forward_reg,
+        ws_forward_data
+       } = ws_to_ds_forward_bus;
 
 // branch
 wire        rj_eq_rd;
@@ -294,7 +302,7 @@ regfile u_regfile(
     .wdata  (rf_wdata )
 );
 
-// stall
+// forward and stall
 assign inst_need_rj  =  inst_add_w  |
                         inst_sub_w  |
                         inst_slt    |
@@ -325,16 +333,18 @@ assign inst_need_rkd =  inst_add_w  |
                         inst_st_w   ;
 
 assign rf1_stall = inst_need_rj &&
-                   (es_stall_valid && (es_stall_reg == rf_raddr1)) ||
-                   (ms_stall_valid && (ms_stall_reg == rf_raddr1)) ||
-                   (ws_stall_valid && (ws_stall_reg == rf_raddr1));
+                   (es_dep_need_stall && (es_forward_reg == rf_raddr1));
 assign rf2_stall = inst_need_rkd &&
-                   (es_stall_valid && (es_stall_reg == rf_raddr2)) ||
-                   (ms_stall_valid && (ms_stall_reg == rf_raddr2)) ||
-                   (ws_stall_valid && (ws_stall_reg == rf_raddr2));
-
-assign rj_value  = rf_rdata1; 
-assign rkd_value = rf_rdata2;
+                   (es_dep_need_stall && (es_forward_reg == rf_raddr2));
+
+assign rj_value  = es_forward_enable && (es_forward_reg == rf_raddr1) ? es_forward_data :
+                   ms_forward_enable && (ms_forward_reg == rf_raddr1) ? ms_forward_data :
+                   ws_forward_enable && (ws_forward_reg == rf_raddr1) ? ws_forward_data :
+                                                                        rf_rdata1; 
+assign rkd_value = es_forward_enable && (es_forward_reg == rf_raddr2) ? es_forward_data :
+                   ms_forward_enable && (ms_forward_reg == rf_raddr2) ? ms_forward_data :
+                   ws_forward_enable && (ws_forward_reg == rf_raddr2) ? ws_forward_data :
+                                                                        rf_rdata2; 
 
 // branch
 assign rj_eq_rd        = (rj_value == rkd_value);
diff --git a/mem_stage.v b/mem_stage.v
index 35a45e7..b22760e 100644
--- a/mem_stage.v
+++ b/mem_stage.v
@@ -13,7 +13,7 @@ module mem_stage(
     output wire                         ms_to_ws_valid,
     output wire [`MS_TO_WS_BUS_WD -1:0] ms_to_ws_bus  ,
     //to ds
-    output  wire [`ES_TO_DS_STALL_BUS - 1:0] ms_to_ds_stall_bus,
+    output  wire [`ES_TO_DS_FORWARD_BUS - 1:0] ms_to_ds_forward_bus,
     //from data sram
     input  wire [31:0] data_sram_rdata
 );
@@ -63,6 +63,6 @@ assign mem_result = data_sram_rdata;
 
 assign ms_final_result = ms_res_from_mem ? mem_result : ms_alu_result;
 
-assign ms_to_ds_stall_bus = {ms_valid && ms_gr_we, ms_dest};
+assign ms_to_ds_forward_bus = {ms_valid && ms_gr_we, ms_dest, ms_final_result};
 
 endmodule
diff --git a/mycpu.h b/mycpu.h
index 166fc5a..79ff114 100644
--- a/mycpu.h
+++ b/mycpu.h
@@ -7,7 +7,7 @@
     `define ES_TO_MS_BUS_WD 71
     `define MS_TO_WS_BUS_WD 70
     `define WS_TO_RF_BUS_WD 38
-    `define ES_TO_DS_STALL_BUS 6
-    `define MS_TO_DS_STALL_BUS 6
-    `define WS_TO_DS_STALL_BUS 6
+    `define ES_TO_DS_FORWARD_BUS 39
+    `define MS_TO_DS_FORWARD_BUS 38
+    `define WS_TO_DS_FORWARD_BUS 38
 `endif
diff --git a/mycpu_top.v b/mycpu_top.v
index ff9b0d7..06a1610 100644
--- a/mycpu_top.v
+++ b/mycpu_top.v
@@ -38,9 +38,9 @@ wire [`ES_TO_MS_BUS_WD -1:0] es_to_ms_bus;
 wire [`MS_TO_WS_BUS_WD -1:0] ms_to_ws_bus;
 wire [`WS_TO_RF_BUS_WD -1:0] ws_to_rf_bus;
 wire [`BR_BUS_WD       -1:0] br_bus;
-wire [`ES_TO_DS_STALL_BUS - 1:0] es_to_ds_stall_bus;
-wire [`MS_TO_DS_STALL_BUS - 1:0] ms_to_ds_stall_bus;
-wire [`WS_TO_DS_STALL_BUS - 1:0] ws_to_ds_stall_bus;
+wire [`ES_TO_DS_FORWARD_BUS - 1:0] es_to_ds_forward_bus;
+wire [`MS_TO_DS_FORWARD_BUS - 1:0] ms_to_ds_forward_bus;
+wire [`WS_TO_DS_FORWARD_BUS - 1:0] ws_to_ds_forward_bus;
 
 // IF stage
 if_stage if_stage(
@@ -70,10 +70,10 @@ id_stage id_stage(
     //from fs
     .fs_to_ds_valid (fs_to_ds_valid ),
     .fs_to_ds_bus   (fs_to_ds_bus   ),
-    //stall
-    .es_to_ds_stall_bus (es_to_ds_stall_bus),
-    .ms_to_ds_stall_bus (ms_to_ds_stall_bus),
-    .ws_to_ds_stall_bus (ws_to_ds_stall_bus),
+    //forward
+    .es_to_ds_forward_bus (es_to_ds_forward_bus),
+    .ms_to_ds_forward_bus (ms_to_ds_forward_bus),
+    .ws_to_ds_forward_bus (ws_to_ds_forward_bus),
     //to es
     .ds_to_es_valid (ds_to_es_valid ),
     .ds_to_es_bus   (ds_to_es_bus   ),
@@ -96,7 +96,7 @@ exe_stage exe_stage(
     .es_to_ms_valid (es_to_ms_valid ),
     .es_to_ms_bus   (es_to_ms_bus   ),
     //to ds
-    .es_to_ds_stall_bus (es_to_ds_stall_bus),
+    .es_to_ds_forward_bus (es_to_ds_forward_bus),
     //data sram interface
     .data_sram_en   (data_sram_en   ),
     .data_sram_we   (data_sram_we   ),
@@ -117,7 +117,7 @@ mem_stage mem_stage(
     .ms_to_ws_valid (ms_to_ws_valid ),
     .ms_to_ws_bus   (ms_to_ws_bus   ),
     //to ds
-    .ms_to_ds_stall_bus (ms_to_ds_stall_bus),
+    .ms_to_ds_forward_bus (ms_to_ds_forward_bus),
     //from data sram
     .data_sram_rdata(data_sram_rdata)
 );
@@ -133,7 +133,7 @@ wb_stage wb_stage(
     //to rf: for write back
     .ws_to_rf_bus   (ws_to_rf_bus   ),
     //to ds
-    .ws_to_ds_stall_bus (ws_to_ds_stall_bus),
+    .ws_to_ds_forward_bus (ws_to_ds_forward_bus),
     //trace debug interface
     .debug_wb_pc      (debug_wb_pc      ),
     .debug_wb_rf_we   (debug_wb_rf_we   ),
diff --git a/wb_stage.v b/wb_stage.v
index 08de170..344cefc 100644
--- a/wb_stage.v
+++ b/wb_stage.v
@@ -11,7 +11,7 @@ module wb_stage(
     //to rf: for write back
     output wire [`WS_TO_RF_BUS_WD -1:0]  ws_to_rf_bus  ,
     //to ds
-    output  wire [`WS_TO_DS_STALL_BUS - 1:0] ws_to_ds_stall_bus,
+    output  wire [`WS_TO_DS_FORWARD_BUS - 1:0] ws_to_ds_forward_bus,
     //trace debug interface
     output wire [31:0] debug_wb_pc     ,
     output wire [ 3:0] debug_wb_rf_we  ,
@@ -60,7 +60,7 @@ assign rf_we    = ws_gr_we && ws_valid;
 assign rf_waddr = ws_dest;
 assign rf_wdata = ws_final_result;
 
-assign ws_to_ds_stall_bus = {ws_valid && ws_gr_we, ws_dest};
+assign ws_to_ds_forward_bus = {ws_valid && ws_gr_we, ws_dest, ws_final_result};
 
 // debug info generate
 assign debug_wb_pc       = ws_pc;
-- 
