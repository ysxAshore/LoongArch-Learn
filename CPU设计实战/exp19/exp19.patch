-    output wire [31:0]                   era_out      
+    output wire [31:0]                   era_out      ,
+    output wire [31:0]                   tlbrentry_out
 );
 
 localparam CRMD  = 14'h0;
@@ -130,9 +142,11 @@ reg [31:0] timer_64;
 
 wire tlbrd_valid_wr_en;
 wire tlbrd_invalid_wr_en;
+wire eret_tlbrefill_excp;
 
