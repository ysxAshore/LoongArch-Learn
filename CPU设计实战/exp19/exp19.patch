+
+assign data_vaddr = es_inst_tlbsrch ? {csr_vppn, 13'b0} : es_alu_result;
 
 wire [3:0] es_stb_wen = {es_alu_result[1:0]==2'b11  ,
                          es_alu_result[1:0]==2'b10  ,
@@ -217,7 +244,7 @@ assign data_wr     = es_mem_we;
 assign {data_wstrb, data_size}  = ({6{es_mem_size[0]}} & {es_stb_wen, 2'b00}) |
