+assign data_addr  = data_paddr;
 assign data_wdata = ({32{es_mem_size[0]}} & es_stb_data ) |
                     ({32{es_mem_size[1]}} & es_sth_data ) |
                     ({32{!es_mem_size  }} & es_rkd_value) ;
