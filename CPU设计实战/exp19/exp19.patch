                        es_inst_tlbrd  ,  //196:196
@@ -192,7 +212,14 @@ wire dep_need_stall = es_valid && (es_res_from_mem | es_div_enable | es_mul_enab
 assign es_to_ds_forward_bus = {dep_need_stall, es_valid && es_gr_we, es_dest, es_final_result};
 
 // mem
-assign data_vaddr = {csr_vppn, 13'b0};
+wire pg_mode = !csr_da && csr_pg;
+wire da_mode =  csr_da && !csr_pg;
+
+assign data_addr_trans_en = pg_mode && !dmw0_en && !dmw1_en;
+assign dmw0_en = pg_mode && ((csr_dmw0[`PLV0] && csr_plv == 2'd0) || (csr_dmw0[`PLV3] && csr_plv == 2'd3)) && (es_alu_result[31:29] == csr_dmw0[`VSEG]);
