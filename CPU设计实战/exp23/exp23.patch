                        es_ertn        ,  //198:198
                        excp           ,  //197:197
                        es_inst_tlbrd  ,  //196:196
@@ -171,8 +183,9 @@ assign es_to_ms_bus = {excp_num       ,  //212:199
                        es_pc             //31:0
                       };
 
-assign es_ready_go    = data_req && data_addr_ok || 
-                        !es_mem_we && !es_res_from_mem && !div_stall || 
+assign es_ready_go    = (data_req || dcacop_op_en) && data_addr_ok || 
+                        icacop_op_en && inst_addr_ok               ||
+                        !es_inst_cacop && !es_mem_we && !es_res_from_mem && !div_stall || 
                         excp;
 assign es_allowin     = !es_valid || es_ready_go && ms_allowin;
 assign es_to_ms_valid =  es_valid && es_ready_go;
@@ -256,6 +269,13 @@ assign data_uncache= (da_mode && (csr_datm == 2'b0))                 ||
                      (dmw1_en && (csr_dmw1[`DMW_MAT] == 2'b0))       ||
                      (data_addr_trans_en && (data_tlb_mat == 2'b0));
 
+assign cacop_op         = es_dest;
+assign cacop_op_mode    = cacop_op[4:3];
+assign icacop_inst      = es_inst_cacop && (cacop_op[2:0] == 3'b0);
+assign icacop_op_en     = icacop_inst && es_valid && ms_allowin && !flush_sign && !ms_excp && !excp;
+assign dcacop_inst      = es_inst_cacop && (cacop_op[2:0] == 3'b1);
+assign dcacop_op_en     = dcacop_inst && es_valid && ms_allowin && !flush_sign && !ms_excp && !excp;
+
 // tlb
 assign es_invtlb_asid = es_rj_value[9:0];
 assign es_invtlb_vpn  = es_rkd_value[31:13];
@@ -272,9 +292,9 @@ assign excp_ale        =  (es_res_from_mem || es_mem_we) & es_valid &
                            (es_mem_size[1] &  es_alu_result[0])                      | 
                            (!es_mem_size   & (es_alu_result[0] | es_alu_result[1]))) ;
 assign excp_tlbr = es_valid && !data_tlb_found && data_addr_trans_en &&
-                   (es_res_from_mem || es_mem_we);
+                   (es_res_from_mem || es_mem_we || es_inst_cacop && cacop_op_mode == 2'd2) ;
 assign excp_pil  = es_valid && !data_tlb_v && data_addr_trans_en && 
-                   es_res_from_mem;
+                   (es_res_from_mem || es_inst_cacop && cacop_op_mode == 2'd2);
 assign excp_pis  = es_valid && es_mem_we       && !data_tlb_v && data_addr_trans_en;
 assign excp_ppi  = es_valid && (es_res_from_mem || es_mem_we) && data_tlb_v && (csr_plv > data_tlb_plv) && data_addr_trans_en;
 assign excp_pme  = es_valid && es_mem_we && data_tlb_v && (csr_plv <= data_tlb_plv) && !data_tlb_d && data_addr_trans_en;
