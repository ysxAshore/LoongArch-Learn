+    end
+    else if (tlbrd_invalid_wr_en) begin
+        csr_asid[`TLB_ASID] <= 10'b0;
+    end
+end
+
+//TLBRENTRY
+always @(posedge clk) begin
+    if (reset) begin
+        csr_tlbrentry[5:0] <= 6'b0;
+    end
+    else if (tlbrentry_wen) begin
+        csr_tlbrentry[`TLBRENTRY_PA] <= wr_data[`TLBRENTRY_PA];
+    end
+end
