+        csr_tlbelo1[`TLB_G]   <= 1'b0;
+        csr_tlbelo1[`TLB_PPN] <= 24'b0;
+    end
+end
+
+//asid
+always @(posedge clk) begin
+    if (reset) begin
+        csr_asid[31:10] <= 22'h280; //ASIDBITS = 10
+    end
+    else if (asid_wen) begin
