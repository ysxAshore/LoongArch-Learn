From 045717241aa964e826dc02fef75168054b683852 Mon Sep 17 00:00:00 2001
From: liangliang678 <wujunliang@loongson.cn>
Date: Thu, 6 Jul 2023 10:00:46 +0800
Subject: [PATCH] exp8

---
 exe_stage.v |  4 +++
 id_stage.v  | 76 +++++++++++++++++++++++++++++++++++++++++++++++++++--
 if_stage.v  |  6 ++++-
 mem_stage.v |  4 +++
 mycpu.h     |  5 +++-
 mycpu_top.v | 13 +++++++++
 wb_stage.v  |  4 +++
 7 files changed, 108 insertions(+), 4 deletions(-)

diff --git a/exe_stage.v b/exe_stage.v
index 6740a5b..acc296f 100644
--- a/exe_stage.v
+++ b/exe_stage.v
@@ -12,6 +12,8 @@ module exe_stage(
     //to ms
     output wire                         es_to_ms_valid,
     output wire [`ES_TO_MS_BUS_WD -1:0] es_to_ms_bus  ,
+    //to ds
+    output wire [`ES_TO_DS_STALL_BUS - 1:0] es_to_ds_stall_bus,
     // data sram interface
     output wire        data_sram_en   ,
     output wire [ 3:0] data_sram_we   ,
@@ -89,6 +91,8 @@ alu u_alu(
     .alu_result (es_alu_result)
 );
 
+assign es_to_ds_stall_bus = {es_valid && es_gr_we, es_dest};
+
 assign data_sram_en    = (es_res_from_mem || es_mem_we) && es_valid;
 assign data_sram_we    = es_mem_we ? 4'hf : 4'h0;
 assign data_sram_addr  = es_alu_result;
diff --git a/id_stage.v b/id_stage.v
index e439634..f00d2ff 100644
--- a/id_stage.v
+++ b/id_stage.v
@@ -9,6 +9,10 @@ module id_stage(
     //from fs 
     input  wire                         fs_to_ds_valid,
     input  wire [`FS_TO_DS_BUS_WD -1:0] fs_to_ds_bus  ,
+    //stall
+    input  wire [`ES_TO_DS_STALL_BUS - 1:0] es_to_ds_stall_bus,
+    input  wire [`MS_TO_DS_STALL_BUS - 1:0] ms_to_ds_stall_bus,
+    input  wire [`WS_TO_DS_STALL_BUS - 1:0] ws_to_ds_stall_bus,
     //to es
     output wire                         ds_to_es_valid,
     output wire [`DS_TO_ES_BUS_WD -1:0] ds_to_es_bus  ,
@@ -105,14 +109,39 @@ wire [31:0] rj_value;
 wire [31:0] rkd_value;
 wire [31:0] ds_imm;
 
+// stall
+wire inst_need_rj;
+wire inst_need_rkd;
+wire rf1_stall;
+wire rf2_stall;
+
+wire       es_stall_valid;
+wire [4:0] es_stall_reg;
+assign {es_stall_valid,
+        es_stall_reg
+       } = es_to_ds_stall_bus;
+
+wire       ms_stall_valid;
+wire [4:0] ms_stall_reg;
+assign {ms_stall_valid,
+        ms_stall_reg
+       } = ms_to_ds_stall_bus;
+
+wire       ws_stall_valid;
+wire [4:0] ws_stall_reg;
+assign {ws_stall_valid,
+        ws_stall_reg
+       } = ws_to_ds_stall_bus;
+
 // branch
 wire        rj_eq_rd;
+wire        br_taken_cancel;
 wire        br_taken;
 
 wire [31:0] br_offs;
 wire [31:0] jirl_offs;
 wire [31:0] br_target;
-assign br_bus       = {br_taken,br_target};
+assign br_bus       = {br_taken_cancel,br_taken,br_target};
 
 assign ds_to_es_bus = {alu_op      ,  //149:138
                        res_from_mem,  //137:137
@@ -127,13 +156,16 @@ assign ds_to_es_bus = {alu_op      ,  //149:138
                        ds_pc          //31 :0
                       };
 
-assign ds_ready_go    = 1'b1;
+assign ds_ready_go    = !(rf1_stall || rf2_stall);
 assign ds_allowin     = !ds_valid || ds_ready_go && es_allowin;
 assign ds_to_es_valid = ds_valid && ds_ready_go;
 always @(posedge clk) begin 
     if (reset) begin     
         ds_valid <= 1'b0;
     end
+    else if (br_taken_cancel) begin
+        ds_valid <= 1'b0;
+    end
     else if (ds_allowin) begin 
         ds_valid <= fs_to_ds_valid;
     end
@@ -262,12 +294,52 @@ regfile u_regfile(
     .wdata  (rf_wdata )
 );
 
+// stall
+assign inst_need_rj  =  inst_add_w  |
+                        inst_sub_w  |
+                        inst_slt    |
+                        inst_sltu   |
+                        inst_nor    |
+                        inst_and    |
+                        inst_or     |
+                        inst_xor    |
+                        inst_addi_w |
+                        inst_slli_w |
+                        inst_srli_w |
+                        inst_srai_w |                      
+                        inst_jirl   |    
+                        inst_beq    |
+                        inst_bne    |
+                        inst_ld_w   |
+                        inst_st_w   ;
+assign inst_need_rkd =  inst_add_w  |
+                        inst_sub_w  |
+                        inst_slt    |
+                        inst_sltu   |
+                        inst_nor    |
+                        inst_and    |
+                        inst_or     |
+                        inst_xor    |
+                        inst_beq    |
+                        inst_bne    |
+                        inst_st_w   ;
+
+assign rf1_stall = inst_need_rj &&
+                   (es_stall_valid && (es_stall_reg == rf_raddr1)) ||
+                   (ms_stall_valid && (ms_stall_reg == rf_raddr1)) ||
+                   (ws_stall_valid && (ws_stall_reg == rf_raddr1));
+assign rf2_stall = inst_need_rkd &&
+                   (es_stall_valid && (es_stall_reg == rf_raddr2)) ||
+                   (ms_stall_valid && (ms_stall_reg == rf_raddr2)) ||
+                   (ws_stall_valid && (ws_stall_reg == rf_raddr2));
+
 assign rj_value  = rf_rdata1; 
 assign rkd_value = rf_rdata2;
 
 // branch
 assign rj_eq_rd        = (rj_value == rkd_value);
 
+assign br_taken_cancel = br_taken && ds_allowin;
 assign br_taken = (   inst_beq  &&  rj_eq_rd
                    || inst_bne  && !rj_eq_rd
                    || inst_jirl
diff --git a/if_stage.v b/if_stage.v
index 207907f..5a629f9 100644
--- a/if_stage.v
+++ b/if_stage.v
@@ -23,9 +23,10 @@ wire        fs_ready_go;
 wire        fs_allowin;
 wire        to_fs_valid;
 
+wire         br_taken_cancel;
 wire         br_taken;
 wire [ 31:0] br_target;
-assign {br_taken, br_target} = br_bus;
+assign {br_taken_cancel, br_taken, br_target} = br_bus;
 
 wire [31:0] fs_inst;
 reg  [31:0] fs_pc;
@@ -50,6 +51,9 @@ always @(posedge clk) begin
     else if (fs_allowin) begin
         fs_valid <= to_fs_valid;
     end
+    else if (br_taken_cancel) begin
+        fs_valid <= 1'b0;
+    end
 
     if (reset) begin
         fs_pc <= 32'h1bfffffc;  //trick: to make nextpc be 0x1c000000 during reset 
diff --git a/mem_stage.v b/mem_stage.v
index a93a73d..35a45e7 100644
--- a/mem_stage.v
+++ b/mem_stage.v
@@ -12,6 +12,8 @@ module mem_stage(
     //to ws
     output wire                         ms_to_ws_valid,
     output wire [`MS_TO_WS_BUS_WD -1:0] ms_to_ws_bus  ,
+    //to ds
+    output  wire [`ES_TO_DS_STALL_BUS - 1:0] ms_to_ds_stall_bus,
     //from data sram
     input  wire [31:0] data_sram_rdata
 );
@@ -61,4 +63,6 @@ assign mem_result = data_sram_rdata;
 
 assign ms_final_result = ms_res_from_mem ? mem_result : ms_alu_result;
 
+assign ms_to_ds_stall_bus = {ms_valid && ms_gr_we, ms_dest};
+
 endmodule
diff --git a/mycpu.h b/mycpu.h
index e132826..166fc5a 100644
--- a/mycpu.h
+++ b/mycpu.h
@@ -1,10 +1,13 @@
 `ifndef MYCPU_H
     `define MYCPU_H
 
-    `define BR_BUS_WD       33
+    `define BR_BUS_WD       34
     `define FS_TO_DS_BUS_WD 64
     `define DS_TO_ES_BUS_WD 150
     `define ES_TO_MS_BUS_WD 71
     `define MS_TO_WS_BUS_WD 70
     `define WS_TO_RF_BUS_WD 38
+    `define ES_TO_DS_STALL_BUS 6
+    `define MS_TO_DS_STALL_BUS 6
+    `define WS_TO_DS_STALL_BUS 6
 `endif
diff --git a/mycpu_top.v b/mycpu_top.v
index 8bc9d78..ff9b0d7 100644
--- a/mycpu_top.v
+++ b/mycpu_top.v
@@ -38,6 +38,9 @@ wire [`ES_TO_MS_BUS_WD -1:0] es_to_ms_bus;
 wire [`MS_TO_WS_BUS_WD -1:0] ms_to_ws_bus;
 wire [`WS_TO_RF_BUS_WD -1:0] ws_to_rf_bus;
 wire [`BR_BUS_WD       -1:0] br_bus;
+wire [`ES_TO_DS_STALL_BUS - 1:0] es_to_ds_stall_bus;
+wire [`MS_TO_DS_STALL_BUS - 1:0] ms_to_ds_stall_bus;
+wire [`WS_TO_DS_STALL_BUS - 1:0] ws_to_ds_stall_bus;
 
 // IF stage
 if_stage if_stage(
@@ -67,6 +70,10 @@ id_stage id_stage(
     //from fs
     .fs_to_ds_valid (fs_to_ds_valid ),
     .fs_to_ds_bus   (fs_to_ds_bus   ),
+    //stall
+    .es_to_ds_stall_bus (es_to_ds_stall_bus),
+    .ms_to_ds_stall_bus (ms_to_ds_stall_bus),
+    .ws_to_ds_stall_bus (ws_to_ds_stall_bus),
     //to es
     .ds_to_es_valid (ds_to_es_valid ),
     .ds_to_es_bus   (ds_to_es_bus   ),
@@ -88,6 +95,8 @@ exe_stage exe_stage(
     //to ms
     .es_to_ms_valid (es_to_ms_valid ),
     .es_to_ms_bus   (es_to_ms_bus   ),
+    //to ds
+    .es_to_ds_stall_bus (es_to_ds_stall_bus),
     //data sram interface
     .data_sram_en   (data_sram_en   ),
     .data_sram_we   (data_sram_we   ),
@@ -107,6 +116,8 @@ mem_stage mem_stage(
     //to ws
     .ms_to_ws_valid (ms_to_ws_valid ),
     .ms_to_ws_bus   (ms_to_ws_bus   ),
+    //to ds
+    .ms_to_ds_stall_bus (ms_to_ds_stall_bus),
     //from data sram
     .data_sram_rdata(data_sram_rdata)
 );
@@ -121,6 +132,8 @@ wb_stage wb_stage(
     .ms_to_ws_bus   (ms_to_ws_bus   ),
     //to rf: for write back
     .ws_to_rf_bus   (ws_to_rf_bus   ),
+    //to ds
+    .ws_to_ds_stall_bus (ws_to_ds_stall_bus),
     //trace debug interface
     .debug_wb_pc      (debug_wb_pc      ),
     .debug_wb_rf_we   (debug_wb_rf_we   ),
diff --git a/wb_stage.v b/wb_stage.v
index e958e24..08de170 100644
--- a/wb_stage.v
+++ b/wb_stage.v
@@ -10,6 +10,8 @@ module wb_stage(
     input  wire [`MS_TO_WS_BUS_WD -1:0]  ms_to_ws_bus  ,
     //to rf: for write back
     output wire [`WS_TO_RF_BUS_WD -1:0]  ws_to_rf_bus  ,
+    //to ds
+    output  wire [`WS_TO_DS_STALL_BUS - 1:0] ws_to_ds_stall_bus,
     //trace debug interface
     output wire [31:0] debug_wb_pc     ,
     output wire [ 3:0] debug_wb_rf_we  ,
@@ -58,6 +60,8 @@ assign rf_we    = ws_gr_we && ws_valid;
 assign rf_waddr = ws_dest;
 assign rf_wdata = ws_final_result;
 
+assign ws_to_ds_stall_bus = {ws_valid && ws_gr_we, ws_dest};
+
 // debug info generate
 assign debug_wb_pc       = ws_pc;
 assign debug_wb_rf_we    = {4{rf_we}};
-- 
